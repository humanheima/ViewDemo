<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FA"
    android:orientation="vertical">

    <!-- 顶部标题栏 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:text="桌面小组件 Demo"
        android:textColor="#101828"
        android:textSize="18sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 状态卡片 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text="就绪，点击下方按钮操作小组件"
                    android:textColor="#344054"
                    android:textSize="14sp" />
            </androidx.cardview.widget.CardView>

            <!-- Step 1 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Step 1 — 添加小组件到桌面"
                android:textColor="#667085"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_pin_widget"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="28dp"
                android:backgroundTint="#2F5BEA"
                android:text="添加小组件到桌面"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <!-- Step 2 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Step 2 — 模拟网络请求刷新小组件"
                android:textColor="#667085"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_simulate_refresh"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:backgroundTint="#17B26A"
                android:text="模拟网络请求并更新小组件"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <ProgressBar
                android:id="@+id/progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="6dp"
                android:indeterminate="true"
                android:visibility="gone" />

            <!-- 执行日志 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="8dp"
                android:text="执行日志"
                android:textColor="#667085"
                android:textSize="13sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <TextView
                    android:id="@+id/tv_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:minHeight="120dp"
                    android:padding="14dp"
                    android:textColor="#344054"
                    android:textSize="13sp" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
