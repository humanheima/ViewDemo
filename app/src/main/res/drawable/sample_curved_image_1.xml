<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">

    <!-- 渐变背景 -->
    <path
        android:pathData="M0,0 L200,0 L200,200 L0,200 Z"
        android:fillType="evenOdd">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startColor="#FF6B73"
                android:endColor="#009FDF"
                android:angle="45" />
        </aapt:attr>
    </path>

    <!-- 中心圆圈 -->
    <path
        android:pathData="M 100 40 A 60 60 0 1 0 100 160 A 60 60 0 1 0 100 40 Z"
        android:fillColor="#FFFFFF"
        android:strokeColor="#333333"
        android:strokeWidth="4" />

    <!-- 中心文字区域 -->
    <path
        android:pathData="M60,90 L140,90 L140,110 L60,110 Z"
        android:fillColor="#FF6B73" />

</vector>
